{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "node": "22.13.0",
      "pnpm": "11.4.0",
      "env": {
        "DATABASE_URL": "postgresql://build:build@127.0.0.1:5432/build?sslmode=require"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "node": "22.13.0",
      "pnpm": "11.4.0",
      "autoIncrement": true,
      "env": {
        "DATABASE_URL": "postgresql://build:build@127.0.0.1:5432/build?sslmode=require"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
