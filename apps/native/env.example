# Copier vers apps/native/.env (local) — ne pas committer .env
# Builds EAS cloud : eas env:create (voir DEPLOY.md)

# --- Prod (défaut) ---
EXPO_PUBLIC_API_URL=https://todolist.ez3ki33l.ovh

# --- Dev local sur téléphone physique ---
# Remplacer par l'IP LAN de votre PC (même réseau Wi‑Fi que le téléphone).
# EXPO_PUBLIC_API_URL=http://192.168.1.30:3000
# Terminal séparé : pnpm --filter web dev
# Après modification du .env : npx expo start -c (ou relancer pnpm android)

# Clerk (dashboard → API Keys → Publishable key — pas de placeholder)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Google Sign-In natif (client Web — même que Clerk SSO custom credentials)
EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=782595741716-6ebvh8k73pbeta3hpcqapq4jj7lrtk6d.apps.googleusercontent.com

EXPO_PUBLIC_EAS_PROJECT_ID=7880f051-0127-48d4-a656-b19916a7e1f4
