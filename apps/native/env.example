# Copier vers apps/native/.env (local) — ne pas committer .env
# Builds EAS cloud : eas env:create (voir DEPLOY.md)

# URL de l'API (prod ou dev local)
EXPO_PUBLIC_API_URL=https://your-api.example.com

# Dev local sur téléphone physique (même réseau Wi‑Fi que le PC) :
# EXPO_PUBLIC_API_URL=http://192.168.1.x:3000
# Terminal séparé : pnpm --filter web dev
# Après modification du .env : npx expo start -c

# Clerk (dashboard → API Keys → Publishable key)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Google Sign-In natif (Clerk → Google SSO + Google Cloud → Credentials)
EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_CLERK_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Expo / EAS (expo.dev → projet → Project ID)
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
