{
  "name": "native",
  "version": "1.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start -c",
    "start": "EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:components": "vitest run components/"
  },
  "dependencies": {
    "@babel/runtime": "~7.29.7",
    "@clerk/expo": "^3.4.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-community/datetimepicker": "8.6.0",
    "@repo/api": "workspace:*",
    "@repo/domain": "workspace:*",
    "@repo/emoji": "workspace:*",
    "@repo/theme": "workspace:*",
    "@tamagui/config": "^2.3.0",
    "@tanstack/react-query": "^5.80.5",
    "@trpc/client": "catalog:",
    "@trpc/react-query": "catalog:",
    "expo": "^55.0.4",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-notifications": "~55.0.10",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.14",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-gesture-handler": "^2.30.1",
    "react-native-reanimated": "^4.4.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.9.1",
    "tamagui": "^2.3.0"
  },
  "devDependencies": {
    "@tamagui/babel-plugin": "^2.3.0",
    "@tamagui/metro-plugin": "^2.3.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.10",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.18",
    "jsdom": "^29.1.1",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-worklets",
        "react-native-reanimated"
      ]
    },
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}
