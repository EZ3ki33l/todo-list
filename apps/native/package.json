{
  "name": "native",
  "version": "1.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start --web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "check:google-oauth": "node scripts/verify-google-oauth.mjs",
    "eas-build-post-install": "node scripts/verify-google-oauth.mjs"
  },
  "dependencies": {
    "@babel/runtime": "~7.29.7",
    "@expo/ngrok": "^4.1.3",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@repo/api": "workspace:*",
    "@tanstack/react-query": "^5.80.5",
    "@trpc/client": "catalog:",
    "@trpc/react-query": "catalog:",
    "expo": "^55.0.4",
    "expo-constants": "~55.0.7",
    "expo-device": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-notifications": "~55.0.10",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.14",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "^2.30.1",
    "react-native-reanimated": "^4.4.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.9.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "typescript": "5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-worklets",
        "react-native-reanimated"
      ]
    },
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}
