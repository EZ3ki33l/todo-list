generator client {
  provider             = "prisma-client"
  output               = "../src/generated/prisma"
  importFileExtension  = "ts"
}

datasource db {
  provider = "postgresql"
}

/// Propriétaire d'une liste ou membre invité (liste partagée).
enum ListMemberRole {
  Propriétaire
  membre
  invité
}

/// Statut d'une todo-list.
enum ListStatus {
  ACTIVE
  ARCHIVED
  DONE
}

/// Récurrence d'une action.
enum Recurrence {
  NONE    // tâche ponctuelle
  DAILY   // chaque jour
  WEEKLY  // chaque semaine, même jour
}

/// Catégorie d'un article de courses (utilisée pour fallback d'icône et tri/groupement).
enum GroceryCategory {
  LEGUME
  FRUIT
  VIANDE
  POISSON
  BOULANGERIE
  EPICERIE
  LAITIER
  BOISSON
  HYGIENE
  AUTRE
}

/// Utilisateur applicatif (profil Clerk + données métier).
model User {
  id            String    @id @default(cuid())
  clerkId       String?   @unique
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts            Account[]
  sessions            Session[]
  ownedLists          TodoList[]           @relation("ListOwner")
  memberships         TodoListMember[]
  ownedShoppingLists  ShoppingList[]       @relation("ShoppingListOwner")
  shoppingMemberships ShoppingListMember[]
  pushTokens          PushToken[]
  webPushSubscriptions WebPushSubscription[]
  shoppingItemStats   ShoppingItemStat[]
  activityEvents           ActivityEvent[]           @relation("ActivityRecipient")
  activityAsActor          ActivityEvent[]           @relation("ActivityActor")
  notificationPreferences  NotificationPreferences?
}

/// Préférences de notifications par utilisateur (web + native).
model NotificationPreferences {
  userId String @id

  alertsEnabled      Boolean @default(true)
  shoppingItemsAdded Boolean @default(true)
  shoppingListShared Boolean @default(true)
  todoListShared     Boolean @default(true)

  /// Popups Notification API (web uniquement).
  browserPopups      Boolean @default(false)
  /// Compteur dans le titre de l'onglet (web uniquement).
  browserTitleBadge  Boolean @default(true)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Type d'événement affiché dans l'historique / cloche.
enum ActivityEventType {
  SHOPPING_LIST_SHARED
  SHOPPING_ITEMS_ADDED
  TODO_LIST_SHARED
}

/// Liste concernée par un événement d'activité.
enum ActivityListKind {
  TODO
  SHOPPING
}

/// Événement persistant pour l'historique in-app (web + native).
model ActivityEvent {
  id          String             @id @default(cuid())
  userId      String
  actorUserId String?
  type        ActivityEventType
  listKind    ActivityListKind?
  listId      String?
  listTitle   String?
  title       String
  body        String
  readAt      DateTime?
  createdAt   DateTime           @default(now())

  user  User  @relation("ActivityRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

/// Habitudes d'achat par utilisateur (articles récurrents + catégorie mémorisée).
model ShoppingItemStat {
  id         String          @id @default(cuid())
  userId     String
  titleNorm  String
  title      String
  category   GroceryCategory @default(AUTRE)
  quantity   Float?
  unit       String?
  useCount   Int             @default(1)
  lastUsedAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, titleNorm])
  @@index([userId, useCount])
}

/// Abonnement Web Push (navigateur) pour notifications hors onglet.
model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Token Expo Push (app native) pour les notifications.
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Lot de notifications courses en attente (regroupement des ajouts rapides).
model ShoppingNotifyBatch {
  listId        String
  actorUserId   String
  itemCount     Int
  lastTitle     String
  lastQuantity  Float?
  lastUnit      String?
  sendAfter     DateTime

  @@unique([listId, actorUserId])
  @@index([sendAfter])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Une todo-list : appartient à un utilisateur, peut être partagée via TodoListMember.
model TodoList {
  id        String     @id @default(cuid())
  title     String
  status    ListStatus @default(ACTIVE)
  ownerId   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  owner   User             @relation("ListOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members TodoListMember[]
  actions Action[]

  @@index([ownerId, status])
}

/// Accès à une liste partagée (en plus du propriétaire défini par ownerId).
model TodoListMember {
  id       String         @id @default(cuid())
  listId   String
  userId   String
  role     ListMemberRole @default(membre)
  joinedAt DateTime       @default(now())

  list TodoList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
  @@index([userId])
  @@index([listId])
}

/// Une action dans une liste : titre, fait / pas fait, planification optionnelle.
model Action {
  id             String     @id @default(cuid())
  listId         String
  title          String
  done           Boolean    @default(false)
  doneAt         DateTime?  // dernière validation (réinitialise l'affichage des tâches récurrentes)
  streakCount    Int        @default(0) // série en cours (récurrentes uniquement)
  bestStreak     Int        @default(0)
  lastStreakPeriod String?  // clé du dernier jour/semaine compté (ex. "2026-05-29")
  dueAt          DateTime?  // date d'échéance (tâche ponctuelle)
  recurrence     Recurrence @default(NONE)
  recurrenceTime String?    // heure de la récurrence au format "HH:mm"
  recurrenceDow  Int?       // jour de la semaine (0=dim..6=sam) pour WEEKLY
  position       Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  list TodoList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@index([dueAt])
  @@index([recurrence])
}

/// Une liste de courses : appartient à un utilisateur, peut être partagée via ShoppingListMember.
model ShoppingList {
  id        String     @id @default(cuid())
  title     String
  status    ListStatus @default(ACTIVE)
  ownerId   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  owner   User                 @relation("ShoppingListOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members ShoppingListMember[]
  items   ShoppingItem[]

  @@index([ownerId, status])
}

/// Accès à une liste de courses partagée (en plus du propriétaire défini par ownerId).
model ShoppingListMember {
  id       String         @id @default(cuid())
  listId   String
  userId   String
  role     ListMemberRole @default(membre)
  joinedAt DateTime       @default(now())

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
  @@index([userId])
  @@index([listId])
}

/// Un article dans une liste de courses : titre, quantité optionnelle, catégorie et icône.
model ShoppingItem {
  id        String          @id @default(cuid())
  listId    String
  title     String
  quantity  Float?          // null = pas de quantité spécifiée
  unit      String?         // "kg", "g", "L", "botte", "pcs"... libre
  category  GroceryCategory @default(AUTRE)
  icon      String?         // nom MaterialCommunityIcons spécifique, null = fallback catégorie
  checked   Boolean         @default(false)
  position  Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
}
